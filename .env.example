# ── Email delivery ──────────────────────────────────────────
EMAIL_ADDRESS=your@email.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_TO=your@email.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Adzuna API (covers Indeed + Jora — free at developer.adzuna.com) ─
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Google Programmable Search Engine (recruiter contact lookup) ─────────────
# Setup: https://programmablesearchengine.google.com/ → new engine, "Search the entire web" ON
# API key: https://console.cloud.google.com/ → APIs & Services → Credentials → API key
# Free tier: 100 queries/day. Leave blank to use fallback LinkedIn search URL.
GOOGLE_CSE_ID=your_search_engine_cx_id
GOOGLE_CSE_API_KEY=your_google_api_key

# ── IMAP (for LinkedIn/Seek alert email parsing) ─────────────
IMAP_SERVER=imap.gmail.com
IMAP_EMAIL=your@email.com
IMAP_PASSWORD=your_app_password_here
IMAP_FOLDER=INBOX

# ── HTTP API (frontend integration) ──────────────────────────
# Leave API_PASSWORD blank to run open (localhost dev). Set it to require login.
API_PASSWORD=
# Long random string. If unset, the server generates an ephemeral one and
# existing sessions invalidate on every restart.
API_SESSION_SECRET=
# Comma-separated list of frontend origins allowed via CORS.
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Optional override; defaults to sqlite:///data/api.sqlite
# JOBRADAR_DB_URL=sqlite:///data/api.sqlite
